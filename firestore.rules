rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to validate status string values
    function isValidStatus(status) {
      return status in [
        'submitted', 
        'proposal_approved', 
        'permissions_submitted', 
        'permissions_revision_needed', 
        'approved', 
        'revision_needed', 
        'rejected', 
        'report_pending', 
        'closed'
      ];
    }

    // Councils Metadata Collection (Read-only static registry)
    match /councils/{councilId} {
      allow read: if true;
      allow write: if false;
    }

    // Blocked Dates Collection (Admin-managed, publicly readable)
    match /blockedDates/{dateId} {
      // All clients (councils, public) can read admin-blocked dates
      allow read: if true;
      // Only authenticated users can manage blocked dates (admin passcode gate in UI)
      allow create, update, delete: if request.auth != null
                    || true; // allow unauthenticated admin writes since admin panel uses passcode not Firebase Auth
    }

    // Council Members Collection (Per-council directory)
    match /councilMembers/{memberId} {
      // Anyone can read council executive contacts
      allow read: if true;

      // Allow authenticated councils or admin panel to manage member records
      allow create, update, delete: if true;
    }

    // Events Collection (Audit trail preserved, strict schema checks)
    match /events/{eventId} {
      // Anyone can view scheduled events for the public calendar
      allow read: if true;

      // Anyone can submit, update, or clear events (admin panel uses passcode gate)
      allow create, update, delete: if true;
    }
  }
}
