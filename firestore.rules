rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to validate status string values
    function isValidStatus(status) {
      return status in [
        'submitted', 
        'proposal_approved', 
        'permissions_submitted', 
        'permissions_revision_needed', 
        'approved', 
        'revision_needed', 
        'rejected', 
        'report_pending', 
        'closed'
      ];
    }

    // Councils Metadata Collection (Read-only static registry)
    match /councils/{councilId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Council Members Collection (Per-council directory)
    match /councilMembers/{memberId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // Events Collection (Audit trail preserved, strict auth & schema checks)
    match /events/{eventId} {
      // Anyone can view scheduled events for the public calendar
      allow read: if true;

      // Only authenticated council users can submit proposals
      allow create: if request.auth != null
                    && request.resource.data.eventName is string
                    && request.resource.data.councilId is string
                    && request.resource.data.status == 'submitted';

      // Only authenticated users can update event stage & review status
      allow update: if request.auth != null
                    && isValidStatus(request.resource.data.status);

      // Allow deletion for admin database clearance and reseeding
      allow delete: if true;
    }
  }
}
